{
  "name": "game-launcher-web",
  "version": "0.1.0",
  "private": true,
  "description": "Web-based party game launcher for Space Console — a 10-foot TV UI (webOS, Android TV, tvOS) and desktop browsers, AirConsole-style.",
  "type": "module",
  "scripts": {
    "dev": "live-server --port=5173 --no-browser --entry-file=index.html .",
    "start": "serve --listen 5173 .",
    "preview": "serve --listen 5173 .",
    "lint": "eslint .",
    "build": "node scripts/stamp.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "live-server": "^1.2.2",
    "serve": "^14.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
